{
  "expo": {
    "name": "LoadQ",
    "slug": "loadq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "loadq",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#07090F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ca.loadq.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07090F"
      },
      "package": "ca.loadq.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@stripe/stripe-react-native",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "LoadQ needs your location to detect when you enter a loading zone.",
          "locationWhenInUsePermission": "LoadQ needs your location to detect when you enter a loading zone."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2ECC8F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
